{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SafetyPolicy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "tier": {
      "type": "string",
      "enum": ["global", "workflow", "job"],
      "description": "Policy tier. Empty/missing means global."
    },
    "selector": {"$ref": "#/definitions/policySelector"},
    "default_tenant": {"type": "string"},
    "default_decision": {
      "type": "string",
      "enum": ["allow", "deny"],
      "description": "Default decision when no rule matches (default: deny = fail-closed)"
    },
    "rules": {
      "type": "array",
      "items": {"$ref": "#/definitions/rule"}
    },
    "output_rules": {
      "type": "array",
      "items": {"$ref": "#/definitions/outputRule"}
    },
    "input_rules": {
      "type": "array",
      "items": {"$ref": "#/definitions/inputRule"}
    },
    "input_policy": {
      "$ref": "#/definitions/inputPolicy"
    },
    "output_policy": {
      "$ref": "#/definitions/outputPolicy"
    },
    "tenants": {
      "type": "object",
      "additionalProperties": {"$ref": "#/definitions/tenantPolicy"}
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "tier": {
          "type": "string",
          "enum": ["global", "workflow", "job"],
          "description": "Rule tier. Empty/missing inherits the fragment tier or global."
        },
        "selector": {"$ref": "#/definitions/policySelector"},
        "match": {"$ref": "#/definitions/policyMatch"},
        "decision": {
          "type": "string",
          "enum": ["allow", "permit", "deny", "block", "require_approval", "require-approval", "require_human", "allow_with_constraints", "allow-with-constraints", "throttle"]
        },
        "reason": {"type": "string"},
        "velocity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_requests", "window_seconds", "key"],
          "properties": {
            "max_requests": {"type": "integer", "minimum": 1},
            "window_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
            "key": {"type": "string", "minLength": 1}
          }
        },
        "constraints": {"$ref": "#/definitions/constraints"},
        "remediations": {
          "type": "array",
          "items": {"$ref": "#/definitions/remediation"}
        }
      }
    },
    "outputRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "enabled": {"type": "boolean"},
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": {"type": "string"},
        "match": {"$ref": "#/definitions/outputMatch"},
        "decision": {
          "type": "string",
          "enum": ["allow", "deny", "quarantine", "redact"]
        },
        "reason": {"type": "string"}
      }
    },
    "policySelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_id": {"type": "string"},
        "job_id": {"type": "string"},
        "session_id": {"type": "string"}
      }
    },
    "inputRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "tier": {
          "type": "string",
          "enum": ["global", "workflow", "job"],
          "description": "Input rule tier. Empty/missing inherits the fragment tier or global."
        },
        "selector": {"$ref": "#/definitions/policySelector"},
        "enabled": {"type": "boolean"},
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": {"type": "string"},
        "match": {"$ref": "#/definitions/inputMatch"},
        "decision": {
          "type": "string",
          "enum": ["deny", "require_approval", "require-approval", "require_human"]
        },
        "reason": {"type": "string"}
      }
    },
    "inputMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenants": {"type": "array", "items": {"type": "string"}},
        "topics": {"type": "array", "items": {"type": "string"}},
        "capabilities": {"type": "array", "items": {"type": "string"}},
        "risk_tags": {"type": "array", "items": {"type": "string"}},
        "scanners": {"type": "array", "items": {"type": "string"}},
        "content_patterns": {"type": "array", "items": {"type": "string"}},
        "keywords": {"type": "array", "items": {"type": "string"}},
        "content_types": {"type": "array", "items": {"type": "string"}},
        "detectors": {"type": "array", "items": {"type": "string"}},
        "input_size_gt": {"type": "integer", "minimum": 0},
        "max_input_bytes": {"type": "integer", "minimum": 0},
        "scope": {"$ref": "#/definitions/scopeConfig"}
      }
    },
    "scopeConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instruction_path", "items_path"],
      "properties": {
        "instruction_path": {"type": "string", "minLength": 1},
        "items_path": {"type": "string", "minLength": 1},
        "category_path": {"type": "string"},
        "name_path": {"type": "string"},
        "allowed_categories": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "aliases": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "on_missing_input": {"type": "string", "enum": ["deny", "allow"]},
        "on_ambiguous": {"type": "string", "enum": ["deny", "allow"]}
      }
    },
    "inputPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "fail_mode": {
          "type": "string",
          "enum": ["open", "closed"]
        },
        "max_scan_bytes": {"type": "integer"}
      }
    },
    "outputPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "fail_mode": {
          "type": "string",
          "enum": ["open", "closed"]
        }
      }
    },
    "outputMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenants": {"type": "array", "items": {"type": "string"}},
        "topics": {"type": "array", "items": {"type": "string"}},
        "capabilities": {"type": "array", "items": {"type": "string"}},
        "risk_tags": {"type": "array", "items": {"type": "string"}},
        "scanners": {"type": "array", "items": {"type": "string"}},
        "content_patterns": {"type": "array", "items": {"type": "string"}},
        "keywords": {"type": "array", "items": {"type": "string"}},
        "content_types": {"type": "array", "items": {"type": "string"}},
        "detectors": {"type": "array", "items": {"type": "string"}},
        "output_size_gt": {"type": "integer", "minimum": 0},
        "max_output_bytes": {"type": "integer", "minimum": 0},
        "has_error": {"type": "boolean"}
      }
    },
    "policyMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenants": {"type": "array", "items": {"type": "string"}},
        "topics": {"type": "array", "items": {"type": "string"}},
        "capabilities": {"type": "array", "items": {"type": "string"}},
        "risk_tags": {"type": "array", "items": {"type": "string"}},
        "requires": {"type": "array", "items": {"type": "string"}},
        "pack_ids": {"type": "array", "items": {"type": "string"}},
        "actor_ids": {"type": "array", "items": {"type": "string"}},
        "actor_types": {"type": "array", "items": {"type": "string"}},
        "agent_risk_tiers": {"type": "array", "items": {"type": "string"}},
        "agent_data_classifications": {"type": "array", "items": {"type": "string"}},
        "labels": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "label_allowlist": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "label_threshold": {
          "type": "object",
          "additionalProperties": {"type": "number"}
        },
        "secrets_present": {"type": "boolean"},
        "predicate": {"type": "string"},
        "delegation": {"$ref": "#/definitions/delegationMatch"},
        "mcp": {"$ref": "#/definitions/mcpPolicy"}
      }
    },
    "delegationMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_depth": {"type": "integer", "minimum": 0},
        "issuers": {"type": "array", "items": {"type": "string"}},
        "require_issuer": {"type": "string"},
        "required_scope": {"type": "array", "items": {"type": "string"}},
        "forbid_delegated": {"type": "boolean"}
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "budgets": {"$ref": "#/definitions/budgetConstraints"},
        "sandbox": {"$ref": "#/definitions/sandboxProfile"},
        "toolchain": {"$ref": "#/definitions/toolchainConstraints"},
        "diff": {"$ref": "#/definitions/diffConstraints"},
        "redaction_level": {"type": "string"},
        "max_output_bytes": {"type": "integer", "minimum": 0, "maximum": 16777216},
        "allowed_destinations": {"type": "array", "items": {"type": "string"}},
        "redact_patterns": {"type": "array", "items": {"type": "string"}}
      }
    },
    "budgetConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_runtime_ms": {"type": "integer", "minimum": 0},
        "max_retries": {"type": "integer", "minimum": 0},
        "max_artifact_bytes": {"type": "integer", "minimum": 0},
        "max_concurrent_jobs": {"type": "integer", "minimum": 0}
      }
    },
    "sandboxProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isolated": {"type": "boolean"},
        "network_allowlist": {"type": "array", "items": {"type": "string"}},
        "fs_read_only": {"type": "array", "items": {"type": "string"}},
        "fs_read_write": {"type": "array", "items": {"type": "string"}}
      }
    },
    "toolchainConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_tools": {"type": "array", "items": {"type": "string"}},
        "allowed_commands": {"type": "array", "items": {"type": "string"}}
      }
    },
    "diffConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_files": {"type": "integer", "minimum": 0},
        "max_lines": {"type": "integer", "minimum": 0},
        "deny_path_globs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "summary": {"type": "string"},
        "replacement_topic": {"type": "string"},
        "replacement_capability": {"type": "string"},
        "add_labels": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "remove_labels": {"type": "array", "items": {"type": "string"}}
      }
    },
    "mcpPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_servers": {"type": "array", "items": {"type": "string"}},
        "deny_servers": {"type": "array", "items": {"type": "string"}},
        "allow_tools": {"type": "array", "items": {"type": "string"}},
        "deny_tools": {"type": "array", "items": {"type": "string"}},
        "allow_resources": {"type": "array", "items": {"type": "string"}},
        "deny_resources": {"type": "array", "items": {"type": "string"}},
        "allow_actions": {"type": "array", "items": {"type": "string"}},
        "deny_actions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "tenantPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_topics": {"type": "array", "items": {"type": "string"}},
        "deny_topics": {"type": "array", "items": {"type": "string"}},
        "allowed_repo_hosts": {"type": "array", "items": {"type": "string"}},
        "denied_repo_hosts": {"type": "array", "items": {"type": "string"}},
        "max_concurrent_jobs": {"type": "integer", "minimum": 0},
        "mcp": {"$ref": "#/definitions/mcpPolicy"}
      }
    }
  }
}
