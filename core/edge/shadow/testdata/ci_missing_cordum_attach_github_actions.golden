{
  "finding_id": "edge_shadow_ci-attach-github_actions",
  "tenant_id": "tenant-ci",
  "audience": "enterprise",
  "severity": "medium",
  "action_kind": "add_cordum_edge_attach",
  "summary": "Add the cordum-edge-attach step to the CI workflow so the job runs under Cordum Edge governance.",
  "risk_explanation": "A CI workflow invokes an agent action without first attaching cordum-edge. The job runs without Cordum policy, audit, or redaction. Signals: missing_cordum_attach.",
  "recommended_action": "Open a PR adding the `cordum-edge-attach@v1` step (or provider equivalent) ahead of any agent step in the workflow.",
  "safety_notes": [
    "All steps are advisory — Cordum Edge does not auto-execute remediation.",
    "Never substitute live secrets into the placeholders shown below; use your secret-manager / api-key-helper.",
    "Cordum NEVER mutates CI provider repos, workflows, or trust roots; operator opens the PR / sets the env var.",
    "For exception flows, route through POST /api/v1/edge/shadow/exception (EDGE-143.6) so the operator-acked decision is audited."
  ],
  "steps": [
    {
      "id": "add_cordum_edge_attach.snippet",
      "title": "Add cordum-edge-attach to GitHub Actions workflow",
      "kind": "add_cordum_edge_attach",
      "command": "# In .github/workflows/\u003cworkflow\u003e.yml, insert this snippet BEFORE the agent step (yaml):\n      - name: Attach Cordum Edge\n        uses: cordum/cordum-edge-attach@v1\n        with:\n          gateway-url: ${{ secrets.CORDUM_EDGE_GATEWAY }}\n          tenant-id: ${{ secrets.CORDUM_EDGE_TENANT_ID }}",
      "docs_url": "docs/edge/shadow-remediation.md",
      "conditions": [
        "open a PR against the workflow file; do not commit directly to default branch",
        "verify CORDUM_EDGE_GATEWAY + CORDUM_EDGE_TENANT_ID secrets exist in the CI provider's secret store"
      ]
    },
    {
      "id": "add_cordum_edge_attach.verify_attach",
      "title": "After merge, verify the next run attaches under Cordum Edge",
      "kind": "add_cordum_edge_attach",
      "command": "# Re-run the workflow and check the Cordum Edge dashboard for the new run id under `/edge/sessions` (filter source_type=ci).",
      "docs_url": "docs/edge/shadow-remediation.md"
    }
  ],
  "generator_version": "1.0.0",
  "generated_at": "2026-05-17T16:00:00Z",
  "advisory_only": true
