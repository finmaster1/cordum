{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Gateway",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_api_gateway_http_requests_total{namespace=~\"$namespace\"}[$__rate_interval])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_api_gateway_http_requests_total{namespace=~\"$namespace\", status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx/sec"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "title": "P99 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(cordum_api_gateway_http_request_duration_seconds_bucket{namespace=~\"$namespace\"}[$__rate_interval])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Job Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "title": "Job Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_scheduler_jobs_received_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "received"
        },
        {
          "expr": "sum(rate(cordum_scheduler_jobs_dispatched_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "dispatched"
        },
        {
          "expr": "sum(rate(cordum_scheduler_jobs_completed_total{namespace=~\"$namespace\", status=\"JOB_STATUS_SUCCEEDED\"}[$__rate_interval]))",
          "legendFormat": "succeeded"
        },
        {
          "expr": "sum(rate(cordum_scheduler_jobs_completed_total{namespace=~\"$namespace\", status=~\"JOB_STATUS_FAILED.*\"}[$__rate_interval]))",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "title": "Safety Decisions",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_scheduler_jobs_dispatched_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "allowed"
        },
        {
          "expr": "sum(rate(cordum_scheduler_safety_denied_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "denied"
        },
        {
          "expr": "sum(rate(cordum_scheduler_output_policy_quarantined_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "quarantined"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "title": "Dispatch Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cordum_scheduler_scheduler_dispatch_latency_seconds_bucket{namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cordum_scheduler_scheduler_dispatch_latency_seconds_bucket{namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(cordum_scheduler_scheduler_dispatch_latency_seconds_bucket{namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Worker Fleet",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "green" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 19 },
      "id": 7,
      "title": "Active Goroutines",
      "type": "stat",
      "targets": [
        {
          "expr": "cordum_scheduler_scheduler_active_goroutines{namespace=~\"$namespace\"}",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 19 },
      "id": 8,
      "title": "Stale Jobs by State",
      "type": "stat",
      "targets": [
        {
          "expr": "cordum_scheduler_scheduler_stale_jobs{namespace=~\"$namespace\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 19 },
      "id": 9,
      "title": "DLQ Emit Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_scheduler_dlq_emit_failures_total{namespace=~\"$namespace\"}[$__rate_interval])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Workflows & Sagas",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 10,
      "title": "Workflow Runs",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_workflows_started_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "started"
        },
        {
          "expr": "sum(rate(cordum_workflows_completed_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "completed"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 11,
      "title": "Active Sagas",
      "type": "stat",
      "targets": [
        {
          "expr": "cordum_scheduler_saga_active{namespace=~\"$namespace\"}",
          "legendFormat": "active"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 12,
      "title": "Saga Rollbacks",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cordum_scheduler_saga_rollbacks_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "rollbacks"
        },
        {
          "expr": "sum(rate(cordum_scheduler_saga_compensation_failed_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "failed"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cordum", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(cordum_api_gateway_http_requests_total, namespace)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "namespace",
        "query": { "query": "label_values(cordum_api_gateway_http_requests_total, namespace)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(cordum_api_gateway_http_requests_total, pod)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(cordum_api_gateway_http_requests_total, pod)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Cordum Overview",
  "uid": "cordum-overview",
  "version": 1
}
