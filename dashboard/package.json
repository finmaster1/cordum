{
  "name": "cordum-dashboard-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:a11y": "eslint src/ --ext .ts,.tsx --rule '{\"jsx-a11y/alt-text\": \"warn\", \"jsx-a11y/aria-props\": \"warn\", \"jsx-a11y/click-events-have-key-events\": \"off\"}'"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dagrejs/graphlib": "^4.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.55.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.22",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.64.0",
    "react-router-dom": "^7.12.0",
    "reactflow": "^11.11.4",
    "recharts": "^2.15.2",
    "safe-regex2": "^5.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "yaml": "^2.8.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.11.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^28.1.0",
    "msw": "^2.13.5",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "dompurify": ">=3.3.2"
  }
}
