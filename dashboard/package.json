{
  "name": "cordum-dashboard-v2",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:a11y": "eslint src/ --config eslint.a11y.config.mjs",
    "generate-api": "node ./scripts/generate-api.mjs",
    "check-api-codegen": "node ./scripts/check-api-codegen.mjs",
    "lhci:collect": "lhci collect",
    "lhci:assert": "lhci assert",
    "lhci:upload": "lhci upload",
    "lhci:autorun": "lhci autorun",
    "lhci": "start-server-and-test \"vite preview --host --port 4173\" http-get://127.0.0.1:4173/login \"lhci autorun\""
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dagrejs/graphlib": "^4.0.1",
    "@hookform/resolvers": "^5.2.2",
